#!/usr/bin/env python3

import requests
import datetime
import json
from collections import OrderedDict
import os
import sys
import time

# Load .env manually
env_path = os.path.expanduser("~/.env")
if os.path.exists(env_path):
    with open(env_path) as f:
        for line in f:
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                key, val = line.split("=", 1)
                os.environ.setdefault(key.strip(), val.strip())

MAX_RETRIES = 3
RETRY_DELAY = 3

GITHUB_USERNAME = os.getenv("GITHUB_USERNAME")
GITHUB_PAT = os.getenv("GITHUB_PAT")
GITLAB_USERNAME = os.getenv("GITLAB_USERNAME")
GITLAB_PAT = os.getenv("GITLAB_PAT")

today = datetime.date.today()
start_of_week = today - datetime.timedelta(days=6)

theme = sys.argv[1].upper() if len(sys.argv) > 1 else "DARK"
if theme not in ["DARK", "LIGHT"]:
    theme = "DARK"

COLOR_SCHEME_DARK = {0: "#202329", 1: "#0e4429", 2: "#006d32", 3: "#26a641", 4: "#39d353"}
COLOR_SCHEME_LIGHT = {0: "#ebedf0", 1: "#9be9a8", 2: "#40c463", 3: "#30a14e", 4: "#216e39"}

def get_color(count):
    scheme = COLOR_SCHEME_DARK if theme == "DARK" else COLOR_SCHEME_LIGHT
    if count == 0: return scheme[0]
    elif count <= 3: return scheme[1]
    elif count <= 6: return scheme[2]
    elif count <= 9: return scheme[3]
    else: return scheme[4]

def get_weekday_name(weekday):
    return ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"][(weekday + 1) % 7]

def fetch_github(contributions):
    """Fetch GitHub contributions and merge into contributions dict."""
    if not GITHUB_USERNAME or not GITHUB_PAT:
        return

    query = """
    query($user: String!, $from: DateTime!, $to: DateTime!) {
      user(login: $user) {
        contributionsCollection(from: $from, to: $to) {
          contributionCalendar {
            weeks {
              contributionDays {
                date
                contributionCount
                weekday
              }
            }
          }
        }
      }
    }
    """
    variables = {
        "user": GITHUB_USERNAME,
        "from": start_of_week.isoformat() + "T00:00:00Z",
        "to": today.isoformat() + "T23:59:59Z"
    }
    headers = {"Authorization": f"Bearer {GITHUB_PAT}", "Accept": "application/vnd.github.v4.idl"}

    for attempt in range(MAX_RETRIES):
        try:
            if attempt > 0:
                time.sleep(RETRY_DELAY)
            resp = requests.post(
                "https://api.github.com/graphql",
                json={"query": query, "variables": variables},
                headers=headers, timeout=10
            )
            resp.raise_for_status()
            data = resp.json()
            weeks = data["data"]["user"]["contributionsCollection"]["contributionCalendar"]["weeks"]
            for week in weeks:
                for day in week["contributionDays"]:
                    date = datetime.date.fromisoformat(day["date"])
                    if start_of_week <= date <= today:
                        contributions[date] = contributions.get(date, 0) + day["contributionCount"]
            return
        except Exception:
            if attempt == MAX_RETRIES - 1:
                return

def fetch_gitlab(contributions):
    """Fetch GitLab contributions and merge into contributions dict."""
    if not GITLAB_USERNAME or not GITLAB_PAT:
        return

    headers = {"PRIVATE-TOKEN": GITLAB_PAT}
    from_date = start_of_week.isoformat()
    to_date = (today + datetime.timedelta(days=1)).isoformat()

    for attempt in range(MAX_RETRIES):
        try:
            if attempt > 0:
                time.sleep(RETRY_DELAY)

            # Get user ID first
            resp = requests.get(
                f"https://gitlab.com/api/v4/users?username={GITLAB_USERNAME}",
                headers=headers, timeout=10
            )
            resp.raise_for_status()
            users = resp.json()
            if not users:
                return
            user_id = users[0]["id"]

            # Get contribution events (pushes, merge requests, issues, comments)
            page = 1
            while page <= 5:
                resp = requests.get(
                    f"https://gitlab.com/api/v4/users/{user_id}/events",
                    params={"after": from_date, "before": to_date, "per_page": 100, "page": page},
                    headers=headers, timeout=10
                )
                resp.raise_for_status()
                events = resp.json()
                if not events:
                    break
                for event in events:
                    created = event.get("created_at", "")[:10]
                    try:
                        date = datetime.date.fromisoformat(created)
                        if start_of_week <= date <= today:
                            contributions[date] = contributions.get(date, 0) + 1
                    except ValueError:
                        pass
                page += 1
            return
        except Exception:
            if attempt == MAX_RETRIES - 1:
                return

# Initialize contributions for each day of the week
contributions = OrderedDict()
for i in range(7):
    day = start_of_week + datetime.timedelta(days=i)
    contributions[day] = 0

# Fetch from both platforms
fetch_github(contributions)
fetch_gitlab(contributions)

# Build output
dots = []
tooltip_lines = []
total = 0

for date, count in contributions.items():
    color = get_color(count)
    dots.append(f'<span foreground="{color}">\u25a0</span>')
    weekday = get_weekday_name(date.weekday())
    tooltip_lines.append(f"{weekday} ({date.month}/{date.day}): {count} contribution{'s' if count != 1 else ''}")
    total += count

sources = []
if GITHUB_USERNAME: sources.append("GitHub")
if GITLAB_USERNAME: sources.append("GitLab")

output = {
    "text": " ".join(dots),
    "tooltip": "\n".join([
        f"{' + '.join(sources)} ({start_of_week.strftime('%m/%d')} to {today.strftime('%m/%d')})",
        f"Total: {total}"
    ] + tooltip_lines),
    "class": "github-contributions",
    "alt": "Contributions"
}

print(json.dumps(output))


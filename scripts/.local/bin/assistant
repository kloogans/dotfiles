#!/bin/bash
# Local voice assistant: Super+A to toggle.
# Record → Whisper → Ollama → Piper TTS
# All local, all on your hardware.

PIDFILE="/tmp/assistant.pid"
AUDIO="/tmp/assistant.wav"
VOLFILE="/tmp/assistant.vol"
VOICE="/home/james/.local/share/piper-voices/en_US-ryan-medium.onnx"
SYSTEM="You are a helpful voice assistant. Keep responses concise — 1-3 sentences max. Be conversational and natural. No markdown, no bullet points, no special formatting."
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}"
SOCK_PATH="$RUNTIME_DIR/hypr-dictate.sock"

# Auto-start whisper server if needed
if [ ! -S "$SOCK_PATH" ]; then
    nohup hypr-dictate-server >"${RUNTIME_DIR}/hypr-dictate-server.log" 2>&1 &
    for _ in $(seq 1 30); do
        [ -S "$SOCK_PATH" ] && break
        sleep 0.5
    done
    if [ ! -S "$SOCK_PATH" ]; then
        notify-send -u critical -t 5000 "Assistant" "Whisper server failed to start"
        exit 1
    fi
fi

# If recording, stop and process
if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    kill "$(cat "$PIDFILE")" 2>/dev/null
    rm -f "$PIDFILE"

    # Restore volume
    if [ -f "$VOLFILE" ]; then
        wpctl set-volume @DEFAULT_AUDIO_SINK@ "$(cat "$VOLFILE")"
        rm -f "$VOLFILE"
    fi

    notify-send -t 1500 "Assistant" "Thinking..."

    # Transcribe
    QUESTION=$(echo "$AUDIO" | ncat -U "$SOCK_PATH")
    rm -f "$AUDIO"

    if [ -z "$QUESTION" ]; then
        notify-send -t 2000 "Assistant" "No speech detected"
        exit 0
    fi

    notify-send -t 3000 "Assistant" "You: $QUESTION"

    # Ask Ollama
    RESPONSE=$(ollama run qwen3:14b "System: $SYSTEM

User: $QUESTION" 2>/dev/null)

    if [ -z "$RESPONSE" ]; then
        notify-send -t 2000 "Assistant" "No response from Ollama"
        exit 0
    fi

    notify-send -t 5000 "Assistant" "$RESPONSE"

    # Speak it
    echo "$RESPONSE" | piper-tts -m "$VOICE" -f /tmp/assistant-reply.wav 2>/dev/null
    pw-play /tmp/assistant-reply.wav 2>/dev/null &

else
    # Start recording
    wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -oP '[\d.]+' > "$VOLFILE"
    rm -f "$AUDIO"
    pw-record --rate 16000 "$AUDIO" &
    echo $! > "$PIDFILE"
    notify-send -t 1500 "Assistant" "Listening..."
fi

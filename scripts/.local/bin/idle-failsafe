#!/bin/bash
# ============================================================
# IDLE FAILSAFE — the last line of defense
# ============================================================
# Failure scenarios covered:
#
#  1. hypridle died → restart it
#  2. hypridle running but not blanking → blank directly
#  3. Hyprland restarted → kill stale hypridle, restart
#  4. App holding idle inhibitor → independent tracking, don't care
#  5. Shader failed to apply → display-blank retries 5x
#  6. black.glsl deleted/corrupted → recreate it
#  7. hypridle binary broken after update → independent blanking
#  8. hypridle.conf broken → independent blanking
#  9. hyprctl can't connect → retry with socket directly
# 10. Disk full → cap log at 1000 lines
# ============================================================

LOG="$HOME/.cache/idle-failsafe.log"
TIMEOUT=900
BLANK_SCRIPT="$HOME/.local/bin/display-blank"
SHADER="$HOME/.config/hypr/shaders/black.glsl"

SHADER_CONTENTS='#version 300 es
precision highp float;
in vec2 v_texcoord;
uniform sampler2D tex;
out vec4 fragColor;
void main() {
    fragColor = vec4(0.0, 0.0, 0.0, 1.0);
}'

last_fingerprint=""
last_change=$(date +%s)
last_hyprland_pid=""

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG"
    # Cap log file
    if [ "$(wc -l < "$LOG" 2>/dev/null)" -gt 1000 ]; then
        tail -500 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
    fi
}

ensure_shader_exists() {
    if [ ! -f "$SHADER" ] || [ ! -s "$SHADER" ]; then
        log "black.glsl missing or empty — recreating"
        mkdir -p "$(dirname "$SHADER")"
        echo "$SHADER_CONTENTS" > "$SHADER"
    fi
}

ensure_hypridle() {
    if ! pgrep -x hypridle &>/dev/null; then
        log "hypridle dead — restarting via systemctl"
        systemctl --user restart hypridle 2>/dev/null
        sleep 3
        if ! pgrep -x hypridle &>/dev/null; then
            log "systemctl failed — launching directly"
            /usr/bin/hypridle &disown 2>/dev/null
        fi
    fi
}

ensure_config_valid() {
    local conf="$HOME/.config/hypr/hypridle.conf"
    if [ ! -f "$conf" ] || ! grep -q "timeout = $TIMEOUT" "$conf" 2>/dev/null; then
        log "hypridle.conf missing or wrong timeout — recreating"
        cat > "$conf" << 'CONF'
general {
    after_sleep_cmd = ~/.local/bin/display-unblank
}

listener {
    timeout = 900
    on-timeout = ~/.local/bin/display-blank
    on-resume = ~/.local/bin/display-unblank
}
CONF
        # Restart hypridle to pick up the fixed config
        pkill -x hypridle 2>/dev/null
        sleep 1
        ensure_hypridle
    fi
}

check_hyprland_restart() {
    local hypr_pid
    hypr_pid=$(pgrep -x Hyprland 2>/dev/null | head -1)

    if [ -n "$last_hyprland_pid" ] && [ -n "$hypr_pid" ] && [ "$hypr_pid" != "$last_hyprland_pid" ]; then
        log "Hyprland PID changed ($last_hyprland_pid → $hypr_pid) — restarting hypridle"
        pkill -x hypridle 2>/dev/null
        sleep 2
        ensure_hypridle
    fi
    last_hyprland_pid="$hypr_pid"
}

is_blanked() {
    local current
    current=$(hyprctl getoption decoration:screen_shader -j 2>/dev/null | jq -r '.str // empty')
    [[ "$current" == *"black.glsl"* ]]
}

get_idle_seconds() {
    local current_pos current_window fingerprint now
    current_pos=$(hyprctl cursorpos 2>/dev/null)
    current_window=$(hyprctl activewindow -j 2>/dev/null | jq -r '.title // empty')
    fingerprint="${current_pos}|${current_window}"

    if [ "$fingerprint" != "$last_fingerprint" ]; then
        last_fingerprint="$fingerprint"
        last_change=$(date +%s)
    fi

    now=$(date +%s)
    echo $((now - last_change))
}

force_blank() {
    # Try hyprctl first
    hyprctl keyword cursor:no_hardware_cursors true 2>/dev/null
    hyprctl keyword decoration:screen_shader "$SHADER" 2>/dev/null
    hyprctl dispatch submap blank 2>/dev/null

    sleep 0.5
    if ! is_blanked; then
        # Second attempt
        sleep 2
        hyprctl keyword decoration:screen_shader "$SHADER" 2>/dev/null
    fi
}

# ── Startup checks ──
ensure_shader_exists
ensure_config_valid
ensure_hypridle

# ── Main loop ──
while true; do
    ensure_shader_exists
    ensure_hypridle
    check_hyprland_restart

    idle=$(get_idle_seconds)

    if [ "$idle" -ge "$TIMEOUT" ] && ! is_blanked; then
        log "FAILSAFE TRIGGER: idle ${idle}s, not blanked — forcing blank"
        force_blank
        if ! is_blanked; then
            log "CRITICAL: force_blank failed — retrying in 15s"
        fi
    fi

    sleep 15
done

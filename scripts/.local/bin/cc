#!/usr/bin/env python3
"""
Control Center — GTK4 layer-shell panel
Toggle visibility: send SIGUSR1, or use cc-toggle
"""

import gi
gi.require_version("Gtk", "4.0")
gi.require_version("Gtk4LayerShell", "1.0")
gi.require_version("Pango", "1.0")
from gi.repository import Gtk, GLib, Gdk, Gio, Pango
from gi.repository import Gtk4LayerShell as LayerShell

import json, signal, threading, sys, subprocess
from datetime import datetime, date
from urllib.request import urlopen, Request

# ── config ────────────────────────────────────────────────────────────────────
OLLAMA_HOST  = "127.0.0.1"
OLLAMA_PORT  = 11434
OLLAMA_MODEL = "qwen3:14b"
LAT, LON     = 27.77086, -82.67927
PANEL_WIDTH  = 420

# ── WMO weather ───────────────────────────────────────────────────────────────
WMO_DESC = {
    0: "Clear", 1: "Mainly Clear", 2: "Partly Cloudy", 3: "Overcast",
    45: "Fog", 48: "Icy Fog",
    51: "Light Drizzle", 53: "Drizzle", 55: "Heavy Drizzle",
    61: "Light Rain", 63: "Rain", 65: "Heavy Rain",
    71: "Light Snow", 73: "Snow", 75: "Heavy Snow",
    80: "Showers", 81: "Showers", 82: "Heavy Showers",
    95: "Thunderstorm", 96: "Tstorm+Hail", 99: "Tstorm+Hail",
}

def wmo_icon(c):
    if c == 0:          return "☀"
    if c in (1, 2):     return "⛅"
    if c == 3:          return "☁"
    if c in (45, 48):   return "🌫"
    if 51 <= c <= 67:   return "🌧"
    if 71 <= c <= 77:   return "❄"
    if 80 <= c <= 82:   return "🌦"
    if c >= 95:         return "⛈"
    return "~"

def day_label(iso):
    d = datetime.strptime(iso, "%Y-%m-%d").date()
    today = date.today()
    delta = (d - today).days
    if delta == 0: return "Today"
    if delta == 1: return "Tmrw"
    return d.strftime("%a")

# ── system stats ──────────────────────────────────────────────────────────────
_prev_cpu = None

def read_cpu():
    global _prev_cpu
    with open("/proc/stat") as f:
        vals = list(map(int, f.readline().split()[1:8]))
    idle, total = vals[3], sum(vals)
    if _prev_cpu is None:
        _prev_cpu = (total, idle)
        return 0.0
    pt, pi = _prev_cpu
    _prev_cpu = (total, idle)
    dt = total - pt
    return 100.0 * (1 - (idle - pi) / dt) if dt else 0.0

def read_mem():
    info = {}
    with open("/proc/meminfo") as f:
        for line in f:
            k, v = line.split(":")
            info[k.strip()] = int(v.split()[0])
    total = info["MemTotal"]
    used  = total - info["MemAvailable"]
    return used / total * 100, used // 1024, total // 1024

def read_temp():
    for p in ["/sys/class/thermal/thermal_zone0/temp",
              "/sys/class/hwmon/hwmon0/temp1_input"]:
        try:
            with open(p) as f:
                return int(f.read().strip()) // 1000
        except:
            pass
    return None

def read_gpu():
    try:
        out = subprocess.run(
            ["nvidia-smi", "--query-gpu=utilization.gpu,memory.used,memory.total,temperature.gpu",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=3
        ).stdout.strip()
        parts = [p.strip() for p in out.split(",")]
        util = float(parts[0])
        mem_used = int(parts[1])
        mem_total = int(parts[2])
        temp = int(parts[3])
        return util, mem_used, mem_total, temp
    except Exception:
        return None

def read_uptime():
    with open("/proc/uptime") as f:
        secs = float(f.read().split()[0])
    h, m = int(secs // 3600), int((secs % 3600) // 60)
    return f"{h}h {m}m"

# ── CSS ───────────────────────────────────────────────────────────────────────
CSS = """

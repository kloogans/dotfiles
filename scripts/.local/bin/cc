# ── app ───────────────────────────────────────────────────────────────────────
class CC(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="io.homebase.cc")
        self.win = None
        self._digest_busy = False

    def do_activate(self):
        self._build()
        GLib.unix_signal_add(GLib.PRIORITY_HIGH, signal.SIGUSR1, self._toggle)
        self._start_refresh()

    # ── window ────────────────────────────────────────────────────────────────
    def _build(self):
        win = Gtk.ApplicationWindow(application=self)
        self.win = win

        LayerShell.init_for_window(win)
        LayerShell.set_layer(win, LayerShell.Layer.OVERLAY)
        LayerShell.set_anchor(win, LayerShell.Edge.RIGHT, True)
        LayerShell.set_anchor(win, LayerShell.Edge.TOP,   True)
        LayerShell.set_anchor(win, LayerShell.Edge.BOTTOM,True)
        LayerShell.set_exclusive_zone(win, PANEL_WIDTH)
        win.set_size_request(PANEL_WIDTH, -1)

        css = Gtk.CssProvider()
        css.load_from_string(CSS)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        outer = Gtk.ScrolledWindow()
        outer.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        win.set_child(outer)

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        root.add_css_class("root")
        outer.set_child(root)

        # header
        hdr = Gtk.Label(label="◈  CONTROL CENTER")
        hdr.add_css_class("panel-header")
        hdr.set_halign(Gtk.Align.START)
        root.append(hdr)
        root.append(Gtk.Separator())

        # system
        root.append(self._section("SYSTEM"))
        root.append(self._build_stats())
        root.append(Gtk.Separator())

        # weather
        root.append(self._section("WEATHER"))
        root.append(self._build_weather())
        root.append(Gtk.Separator())

        # hn
        root.append(self._section("HACKER NEWS"))
        self._hn_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        root.append(self._hn_box)
        root.append(Gtk.Separator())

        # digest
        root.append(self._section("DIGEST"))
        root.append(self._build_digest())

        win.present()

    def _section(self, text):
        lbl = Gtk.Label(label=text)
        lbl.add_css_class("section-label")
        lbl.set_halign(Gtk.Align.START)
        return lbl

    # ── stats ─────────────────────────────────────────────────────────────────
    def _build_stats(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.add_css_class("stats-box")

        def bar_row(key):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            lbl = Gtk.Label(label=key); lbl.add_css_class("stat-key")
            bar = Gtk.LevelBar(); bar.set_hexpand(True)
            val = Gtk.Label(label="—"); val.add_css_class("stat-val")
            row.append(lbl); row.append(bar); row.append(val)
            box.append(row)
            return bar, val

        self._cpu_bar, self._cpu_val = bar_row("CPU")
        self._ram_bar, self._ram_val = bar_row("RAM")
        self._gpu_bar, self._gpu_val = bar_row("GPU")

        misc = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=16)
        self._temp_lbl   = Gtk.Label(label=""); self._temp_lbl.add_css_class("dim")
        self._gpu_temp_lbl = Gtk.Label(label=""); self._gpu_temp_lbl.add_css_class("dim")
        self._uptime_lbl = Gtk.Label(label=""); self._uptime_lbl.add_css_class("dim")
        misc.append(self._temp_lbl); misc.append(self._gpu_temp_lbl); misc.append(self._uptime_lbl)
        box.append(misc)
        return box

    # ── weather ───────────────────────────────────────────────────────────────
    def _build_weather(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.add_css_class("weather-box")

        self._w_main   = Gtk.Label(label="Loading…")
        self._w_main.add_css_class("weather-main")
        self._w_main.set_halign(Gtk.Align.START)
        self._w_main.set_ellipsize(Pango.EllipsizeMode.END)
        self._w_main.set_max_width_chars(30)

        self._w_detail = Gtk.Label(label="")
        self._w_detail.add_css_class("weather-detail")
        self._w_detail.set_halign(Gtk.Align.START)

        self._w_forecast = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)

        box.append(self._w_main)
        box.append(self._w_detail)
        box.append(self._w_forecast)
        return box

    def _update_weather(self, d):
        cur   = d["current"]
        temp  = round(cur["temperature_2m"])
        feels = round(cur["apparent_temperature"])
        hum   = cur["relative_humidity_2m"]
        code  = cur["weather_code"]

        self._w_main.set_label(f"{wmo_icon(code)}  {temp}°F  —  {WMO_DESC.get(code,'?')}")
        self._w_detail.set_label(f"feels like {feels}°F  ·  humidity {hum}%")

        # clear forecast
        child = self._w_forecast.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self._w_forecast.remove(child)
            child = nxt

        daily = d["daily"]
        for i in range(4):
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
            row.add_css_class("forecast-row")

            day_l = Gtk.Label(label=day_label(daily["time"][i]))
            day_l.add_css_class("forecast-day"); day_l.set_halign(Gtk.Align.START)

            dc = daily["weather_code"][i]
            ic = Gtk.Label(label=wmo_icon(dc))
            ic.add_css_class("forecast-icon")

            desc_l = Gtk.Label(label=WMO_DESC.get(dc, "?"))
            desc_l.add_css_class("forecast-desc"); desc_l.set_halign(Gtk.Align.START)

            hi = round(daily["temperature_2m_max"][i])
            lo = round(daily["temperature_2m_min"][i])
            tmp_l = Gtk.Label(label=f"{lo}–{hi}°F")
            tmp_l.add_css_class("forecast-temps")

            row.append(day_l); row.append(ic); row.append(desc_l); row.append(tmp_l)
            self._w_forecast.append(row)

    # ── HN ────────────────────────────────────────────────────────────────────
    def _update_hn(self, hits):
        child = self._hn_box.get_first_child()
        while child:
            nxt = child.get_next_sibling()
            self._hn_box.remove(child)
            child = nxt

        for i, h in enumerate(hits[:8], 1):
            title = h.get("title", "")
            pts   = h.get("points") or 0
            url   = h.get("url") or f"https://news.ycombinator.com/item?id={h['objectID']}"

            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
            row.add_css_class("hn-row")

            num = Gtk.Label(label=f"{i}.")
            num.add_css_class("hn-num")

            t_lbl = Gtk.Label(label=title)
            t_lbl.add_css_class("hn-title")
            t_lbl.set_halign(Gtk.Align.START)
            t_lbl.set_hexpand(True)
            t_lbl.set_ellipsize(Pango.EllipsizeMode.END)

            pts_lbl = Gtk.Label(label=f"{pts}pts")
            pts_lbl.add_css_class("hn-pts")
            pts_lbl.set_halign(Gtk.Align.END)

            gc = Gtk.GestureClick()
            gc.connect("pressed", lambda g, n, x, y, u=url: Gio.AppInfo.launch_default_for_uri(u, None))
            row.add_controller(gc)

            row.append(num); row.append(t_lbl); row.append(pts_lbl)
            self._hn_box.append(row)

    # ── Digest ────────────────────────────────────────────────────────────────
    def _build_digest(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.add_css_class("digest-box")

        self._digest_lbl = Gtk.Label(label="Loading…")
        self._digest_lbl.add_css_class("digest-text")
        self._digest_lbl.set_halign(Gtk.Align.START)
        self._digest_lbl.set_wrap(True)
        self._digest_lbl.set_wrap_mode(Pango.WrapMode.WORD_CHAR)
        self._digest_lbl.set_xalign(0)
        box.append(self._digest_lbl)

        meta_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self._digest_ts = Gtk.Label(label="")
        self._digest_ts.add_css_class("digest-meta")
        self._digest_ts.set_halign(Gtk.Align.START)
        self._digest_ts.set_hexpand(True)

        btn = Gtk.Button(label="↺ refresh")
        btn.add_css_class("refresh-btn")
        btn.connect("clicked", lambda _: self._async(self._fetch_digest))

        meta_row.append(self._digest_ts)
        meta_row.append(btn)
        box.append(meta_row)
        return box

    def _collect_context(self):
        def run(*args):
            try:
                return subprocess.run(args, capture_output=True, text=True, timeout=5).stdout.strip()
            except:
                return ""

        failed  = run("systemctl", "--user", "--failed", "--plain", "--no-legend")
        errors  = run("journalctl", "-p", "err", "-S", "1 hour ago", "--no-pager", "-n", "10", "--output=cat")
        playing = run("playerctl", "metadata", "--format", "{{artist}} — {{title}}")
        battery = run("sh", "-c", "cat /sys/class/power_supply/BAT*/capacity 2>/dev/null | head -1")
        bat_st  = run("sh", "-c", "cat /sys/class/power_supply/BAT*/status 2>/dev/null | head -1")

        parts = []
        parts.append(f"Failed services: {failed or 'none'}")
        parts.append(f"Recent errors: {errors or 'none'}")
        parts.append(f"Now playing: {playing or 'nothing'}")
        if battery:
            parts.append(f"Battery: {battery}% ({bat_st})")
        return "\n".join(parts)

    def _fetch_digest(self):
        if self._digest_busy:
            return
        self._digest_busy = True
        GLib.idle_add(self._digest_lbl.set_label, "…")
        try:
            ctx  = self._collect_context()
            prompt = (
                "Given this system state, write a plain-text summary of 1-3 lines. "
                "Be terse. Note anything unusual or worth attention. "
                "If everything is fine just say 'All clear.' No markdown, no bullet points.\n\n"
                + ctx
            )
            url  = f"http://{OLLAMA_HOST}:{OLLAMA_PORT}/api/generate"
            data = json.dumps({"model": OLLAMA_MODEL, "prompt": prompt, "stream": False}).encode()
            req  = Request(url, data=data, headers={"Content-Type": "application/json"})
            with urlopen(req, timeout=60) as r:
                text = json.load(r).get("response", "").strip()
            ts = datetime.now().strftime("%-I:%M %p").lower()
            GLib.idle_add(self._digest_lbl.set_label, text)
            GLib.idle_add(self._digest_ts.set_label, f"updated {ts}")
            with open("/tmp/cc-digest.txt", "w") as f:
                f.write(f"[{ts}]\n{text}\n\nraw context:\n{ctx}\n")
        except Exception as e:
            GLib.idle_add(self._digest_lbl.set_label, f"error: {e}")
        finally:
            self._digest_busy = False

    # ── refresh ───────────────────────────────────────────────────────────────
    def _start_refresh(self):
        self._refresh_stats()
        self._async(self._fetch_weather)
        self._async(self._fetch_hn)
        self._async(self._fetch_digest)
        GLib.timeout_add_seconds(3,    self._refresh_stats)
        GLib.timeout_add_seconds(300,  lambda: self._async(self._fetch_weather) or GLib.SOURCE_CONTINUE)
        GLib.timeout_add_seconds(600,  lambda: self._async(self._fetch_hn)      or GLib.SOURCE_CONTINUE)
        GLib.timeout_add_seconds(1800, lambda: self._async(self._fetch_digest)  or GLib.SOURCE_CONTINUE)

    def _async(self, fn):
        threading.Thread(target=fn, daemon=True).start()

    def _refresh_stats(self):
        cpu              = read_cpu()
        mem_pct, mu, mt  = read_mem()
        temp             = read_temp()
        up               = read_uptime()

        self._cpu_bar.set_value(cpu / 100)
        self._cpu_val.set_label(f"{cpu:.0f}%")
        self._cpu_bar.remove_css_class("bar-warn"); self._cpu_bar.remove_css_class("bar-crit")
        if cpu > 80:   self._cpu_bar.add_css_class("bar-crit")
        elif cpu > 50: self._cpu_bar.add_css_class("bar-warn")

        self._ram_bar.set_value(mem_pct / 100)
        self._ram_val.set_label(f"{mu // 1024:.1f} / {mt // 1024:.0f} GB")

        self._temp_lbl.set_label(f"{temp}°C" if temp else "—")
        self._uptime_lbl.set_label(f"up {up}")

        gpu = read_gpu()
        if gpu:
            g_util, g_mem_used, g_mem_total, g_temp = gpu
            self._gpu_bar.set_value(g_util / 100)
            self._gpu_val.set_label(f"{g_util:.0f}%  {g_mem_used / 1024:.1f} / {g_mem_total / 1024:.0f} GB")
            self._gpu_bar.remove_css_class("bar-warn"); self._gpu_bar.remove_css_class("bar-crit")
            if g_util > 80:   self._gpu_bar.add_css_class("bar-crit")
            elif g_util > 50: self._gpu_bar.add_css_class("bar-warn")
            self._gpu_temp_lbl.set_label(f"gpu {g_temp}°C")
        else:
            self._gpu_val.set_label("N/A")

        return GLib.SOURCE_CONTINUE

    def _fetch_weather(self):
        try:
            url = (
                f"https://api.open-meteo.com/v1/forecast"
                f"?latitude={LAT}&longitude={LON}"
                f"&current=temperature_2m,apparent_temperature,weather_code,relative_humidity_2m"
                f"&daily=temperature_2m_max,temperature_2m_min,weather_code"
                f"&temperature_unit=fahrenheit&timezone=America%2FNew_York&forecast_days=4"
            )
            with urlopen(url, timeout=8) as r:
                d = json.load(r)
            GLib.idle_add(self._update_weather, d)
        except Exception:
            GLib.idle_add(self._w_main.set_label, "—  network error")
            GLib.timeout_add_seconds(30, lambda: self._async(self._fetch_weather) or False)

    def _fetch_hn(self):
        try:
            url = "https://hn.algolia.com/api/v1/search?tags=front_page&hitsPerPage=8"
            with urlopen(url, timeout=8) as r:
                hits = json.load(r)["hits"]
            GLib.idle_add(self._update_hn, hits)
        except:
            pass

    def _toggle(self, *_):
        if self.win.get_visible():
            self.win.hide()
        else:
            self.win.present()
        return GLib.SOURCE_CONTINUE


if __name__ == "__main__":
    CC().run(sys.argv)
